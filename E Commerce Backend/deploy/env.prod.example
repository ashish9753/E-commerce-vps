# Copy to /opt/ecommerce-backend/.env on the VPS and fill in real values.
# This file holds runtime secrets — it is NEVER committed or baked into the image.

PORT=5000
NODE_ENV=production

# MongoDB (Atlas connection string or external mongo)
MONGO_URI=

# Redis runs as the "redis" service in docker-compose.prod.yml
REDIS_HOST=redis
REDIS_PORT=6379

ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@tradengine.com

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

GOOGLE_CLIENT_ID=

# IMPORTANT: must be the live frontend origin (HTTPS), NOT localhost.
# Used for Socket.io CORS and secure-cookie behaviour. Comma-separated allowed.
CLIENT_URL=https://e-commerce-frontend-9vtd.onrender.com

COMPANY_NAME=TradeEngine
PENDING_ORDER_TIMEOUT_MIN=30
TZ_OFFSET_HOURS=5.5

UPAYA_API_KEY=
UPAYA_BASE_URL=https://portal-api.upaya.com.np/api/v1/client
